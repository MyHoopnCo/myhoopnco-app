{
  "name": "myhoopnco-app-expo",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
        "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "expo": "~54.0.33",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.12.0",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@types/react": "~19.1.0",
    "jest-expo": "^55.0.16",
    "typescript": "~5.9.2"
  },
  "private": true
}
