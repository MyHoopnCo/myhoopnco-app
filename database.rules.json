{
  "rules": {
    "chats": {
      "$facilityId": {
        "messages": {
          ".read": "auth != null",
          "$messageId": {
            ".write": "auth != null && (auth.token.moderator == true || (!data.exists() && newData.child('senderUid').val() == auth.uid))",
            ".delete": "auth != null && (auth.token.moderator == true || auth.uid == data.child('senderUid').val())"
          }
        }
      }
    }
  }
}
